{
  "name": "portfolio-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "Spec-first monorepo for Portfolio Tracker",
  "packageManager": "pnpm@9",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev:api": "node scripts/check-node.mjs && pnpm --filter @portfolio-tracker/api dev",
    "dev:web": "node scripts/check-node.mjs && pnpm --filter @portfolio-tracker/web dev",
    "dev:api:docker": "docker compose run --rm api",
    "dev:web:docker": "docker compose run --rm web",
    "build": "pnpm --filter @portfolio-tracker/web build",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc -p tsconfig.json --noEmit && pnpm --filter @portfolio-tracker/api typecheck && pnpm --filter @portfolio-tracker/web typecheck",
    "perf:portfolio": "pnpm --filter @portfolio-tracker/api benchmark:portfolio",
    "security:audit": "pnpm audit --prod --audit-level moderate",
    "clean": "node -e \"console.log('clean placeholder')\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@eslint/js": "^9.7.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.5.0",
    "eslint": "^9.7.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.9.0",
    "husky": "^9.1.4",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.1.0",
    "vitest": "^2.0.5"
  }
}
